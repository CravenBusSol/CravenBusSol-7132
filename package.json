{
  "name": "sandbox-app-template",
  "private": true,
  "packageManager": "bun@1.3.5",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "cd packages/web && bunx vite",
    "dev:desktop": "cd packages/desktop && bunx vite",
    "dev:mobile": "cd packages/mobile && bunx expo start",
    "start": "pm2 delete sandbox-app-template-web 2>/dev/null || true; pm2 start ecosystem.config.cjs --update-env",
    "start:server": "cd packages/web && bun run start",
    "pm2:stop": "pm2 stop sandbox-app-template-web",
    "pm2:restart": "pm2 restart sandbox-app-template-web",
    "pm2:logs": "pm2 logs sandbox-app-template-web",
    "pm2:delete": "pm2 delete sandbox-app-template-web",
    "build": "turbo build",
    "lint": "oxlint . --deny-warnings --no-error-on-unmatched-pattern",
    "lint:fix": "oxlint . --fix --deny-warnings --no-error-on-unmatched-pattern",
    "typecheck": "turbo typecheck",
    "db:generate": "turbo db:generate",
    "db:migrate": "turbo db:migrate",
    "db:push": "turbo db:push",
    "db:studio": "turbo db:studio"
  },
  "devDependencies": {
    "@tursodatabase/api": "^1.9.2",
    "@types/bun": "latest",
    "oxlint": "^1.66.0",
    "turbo": "^2"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1023.0",
    "@libsql/client": "^0.17.2",
    "cloudflare": "^5.2.0",
    "pm2": "^7.0.1"
  }
}
